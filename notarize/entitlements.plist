<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for the MATLAB Runtime under the hardened runtime: -->
    <!-- JIT + executable memory (MATLAB JIT-compiles), library validation off -->
    <!-- (Runtime libs aren't signed by your Team ID), and DYLD env vars -->
    <!-- (the app sets DYLD_LIBRARY_PATH to find the Runtime). -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
